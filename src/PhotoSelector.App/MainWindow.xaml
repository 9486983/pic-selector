<Window x:Class="PhotoSelector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:PhotoSelector.App.Converters"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="Photo Selector V3"
        Height="860"
        Width="1500"
        MinHeight="720"
        MinWidth="1180"
        Background="#F5F7FB"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">
    <Window.Resources>
        <conv:RatingStarConverter x:Key="RatingStarConverter" />
        <conv:HexToBrushConverter x:Key="HexToBrushConverter" />

        <SolidColorBrush x:Key="UiBg" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="CardBorder" Color="#D8DEE9"/>
        <SolidColorBrush x:Key="Accent" Color="#2574A9"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#EEF3FA"/>
            <Setter Property="BorderBrush" Value="#D5DFEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Foreground" Value="#1B2430"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E2ECFA"/>
                    <Setter Property="BorderBrush" Value="#C6D8F2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#ECEFF4"/>
                    <Setter Property="BorderBrush" Value="#D6DCE8"/>
                    <Setter Property="Foreground" Value="#9AA4B2"/>
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DFEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DFEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Height" Value="30"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#ECEFF4"/>
                    <Setter Property="Foreground" Value="#9AA4B2"/>
                    <Setter Property="BorderBrush" Value="#D6DCE8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#2574A9"/>
            <Setter Property="Height" Value="28"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="ThumbListBoxItemStyle">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" BorderBrush="#D6DDE8" BorderThickness="1" CornerRadius="10" Background="White">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2574A9" />
                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="2" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF6FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource UiBg}">
        <Grid Name="MainContentRoot" Opacity="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="12,12,12,8">
                <Button Name="BackToGalleryButton" Width="120" Height="34" Margin="0,0,8,0" Content="返回图库" Click="BackToGalleryButton_OnClick" Visibility="Collapsed"/>
                <Button Name="ImportButton" Width="120" Height="34" Margin="0,0,8,0" Content="导入文件夹" Click="ImportButton_OnClick"/>
                <Button Name="AnalyzeSelectedButton" Width="120" Height="34" Margin="0,0,8,0" Content="分析选中" Click="AnalyzeSelectedButton_OnClick"/>
                <Button Name="AnalyzeAllButton" Width="120" Height="34" Margin="0,0,8,0" Content="分析当前" Click="AnalyzeAllButton_OnClick"/>
                <Button Name="ApplyRuleButton" Width="120" Height="34" Margin="0,0,8,0" Content="应用规则" Click="ApplyRuleButton_OnClick"/>
                <Button Name="ExportButton" Width="140" Height="34" Margin="0,0,8,0" Content="导出筛选结果" Click="ExportButton_OnClick"/>
                <TextBox Name="RuleTextBox" Width="520" Height="34" VerticalContentAlignment="Center" Text="overall&gt;0.65 AND sharpness&gt;0.4 AND is_waste==false" />
            </DockPanel>

            <Grid Grid.Row="1" Margin="12,0,12,8">
                <Grid Name="GalleryPage" AllowDrop="True" DragOver="GalleryPage_OnDragOver" Drop="GalleryPage_OnDrop">
                    <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="12" Background="{StaticResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="图库（可拖拽文件夹到本页）" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ListBox Name="GalleryFolderList"
                                     Grid.Row="1"
                                     SelectionMode="Single"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="230" Height="230" Margin="0,0,12,12" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="10" Background="White">
                                            <Grid>
                                                <Grid.Resources>
                                                    <Style TargetType="Button" x:Key="HoverCardActionBtn">
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Resources>
                                                <Border Height="150" Margin="8" Background="#F2F2F2" CornerRadius="8" VerticalAlignment="Top">
                                                    <Image Source="{Binding CoverPath}" Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Bottom" Margin="10,0,10,10">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding FolderPath}" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button Width="72" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Style="{StaticResource HoverCardActionBtn}" Content="进入" Click="OpenLibraryFolder_OnClick" CommandParameter="{Binding}"/>
                                                <Button Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" Style="{StaticResource HoverCardActionBtn}" Content="⋯" Click="OpenLibraryMenu_OnClick" Tag="{Binding}">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="进入文件夹" Click="OpenLibraryFolderFromMenu_OnClick" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <Separator />
                                                            <MenuItem Header="从图库移除" Click="RemoveLibraryFolder_OnClick" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="删除磁盘文件夹" Click="DeleteLibraryFolderDisk_OnClick" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Name="FolderPage" Visibility="Collapsed" SizeChanged="FolderPage_OnSizeChanged">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="390" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0" Background="{StaticResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="分类维度" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TreeView Name="GroupList"
                                      Grid.Row="1"
                                      SelectedItemChanged="GroupTree_OnSelectedItemChanged"
                                      ContextMenuOpening="GroupList_OnContextMenuOpening">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ContextMenu>
                                    <ContextMenu/>
                                </TreeView.ContextMenu>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="11"
                                                     Height="11"
                                                     Margin="0,0,6,0"
                                                     Fill="{Binding ColorSwatch, Converter={StaticResource HexToBrushConverter}}"
                                                     Stroke="#B4C1D1"
                                                     StrokeThickness="0.5"/>
                                            <TextBlock Text="{Binding Title}"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0" Background="{StaticResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,8">
                                <TextBlock Name="FolderTitleText" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
                                <Border CornerRadius="16" Background="#ECF2FA" BorderBrush="#D7E1EF" BorderThickness="1" Padding="10,6" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="排序" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ComboBox Name="SortComboBox" Width="130" SelectionChanged="SortComboBox_OnSelectionChanged" SelectedIndex="0" Margin="0,0,10,0">
                                            <ComboBoxItem Tag="overall_desc">综合分 ↓</ComboBoxItem>
                                            <ComboBoxItem Tag="overall_asc">综合分 ↑</ComboBoxItem>
                                            <ComboBoxItem Tag="sharpness_desc">清晰度 ↓</ComboBoxItem>
                                            <ComboBoxItem Tag="exposure_desc">曝光 ↓</ComboBoxItem>
                                            <ComboBoxItem Tag="face_desc">人数 ↓</ComboBoxItem>
                                            <ComboBoxItem Tag="rating_desc">星级 ↓</ComboBoxItem>
                                            <ComboBoxItem Tag="name_asc">文件名 ↑</ComboBoxItem>
                                        </ComboBox>
                                        <TextBlock Text="每排数量" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <Slider Name="ColumnsSlider" Minimum="1" Maximum="10" Value="5" Width="120" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="ColumnsSlider_OnValueChanged"/>
                                        <TextBlock Name="ColumnsText" Margin="6,0,0,0" VerticalAlignment="Center" MinWidth="20"/>
                                    </StackPanel>
                                </Border>
                            </DockPanel>

                            <ListBox Name="PhotoList"
                                     Grid.Row="1"
                                     SelectionMode="Single"
                                     ItemContainerStyle="{StaticResource ThumbListBoxItemStyle}"
                                     SelectionChanged="PhotoList_OnSelectionChanged"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding ElementName=RootWindow, Path=PhotoColumns}"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=PhotoCardWidth}">
                                            <Grid.Resources>
                                                <Style TargetType="Button" x:Key="HoverActionBtn">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="Button" x:Key="StarBtn">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="1"/>
                                                    <Setter Property="FontSize" Value="16"/>
                                                    <Setter Property="Foreground" Value="#D49B00"/>
                                                </Style>
                                            </Grid.Resources>
                                            <StackPanel Margin="6">
                                                <Border Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=PhotoThumbHeight}" Background="#F2F2F2" CornerRadius="6">
                                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                                                </Border>
                                                <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Text="{Binding FileName}"/>
                                                <TextBlock Foreground="#444" FontSize="12" Text="{Binding ScoreBadge}"/>
                                                <TextBlock Foreground="#666" FontSize="12" Text="{Binding MetaBadge}" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=1}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="1"/>
                                                    <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=2}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="2"/>
                                                    <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=3}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="3"/>
                                                    <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=4}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="4"/>
                                                    <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=5}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="5"/>
                                                </StackPanel>
                                                <TextBlock Foreground="#B00020" FontSize="12" Text="{Binding WasteBadge}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Button Width="24" Height="24" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" Style="{StaticResource HoverActionBtn}" Content="⛶" Click="FullscreenPreview_OnClick" CommandParameter="{Binding}" ToolTip="全屏预览"/>
                                            <Button Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Style="{StaticResource HoverActionBtn}" Content="⋯" Click="OpenRowMenu_OnClick" CommandParameter="{Binding}" ToolTip="更多操作">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="手动标记: 好片" Click="ManualTagGood_OnClick" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <MenuItem Header="手动标记: 废片" Click="ManualTagWaste_OnClick" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <MenuItem Header="手动标记: 人像" Click="ManualTagPortrait_OnClick" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                        <Separator />
                                                        <MenuItem Header="重新分析" Click="Reanalyze_OnClick" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="360" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,8" Background="{StaticResource CardBg}">
                            <Image Name="PreviewImage" Stretch="Uniform"/>
                        </Border>
                        <Border Grid.Row="1" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="12" Background="{StaticResource CardBg}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Name="DetailOverallText" Grid.Row="0" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailSharpnessText" Grid.Row="1" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailExposureText" Grid.Row="2" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailFaceText" Grid.Row="3" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailClassText" Grid.Row="4" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailWasteText" Grid.Row="5" Margin="0,0,0,8"/>
                                    <TextBox Name="DetailRawJsonText"
                                             Grid.Row="6"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             IsReadOnly="True"
                                             Background="#F8FAFD"
                                             BorderBrush="#D5DFEE"
                                             Foreground="#1E2936"
                                             Padding="8"/>
                                </Grid>
                            </Border>
                        </Grid>
                </Grid>
            </Grid>

            <StatusBar Grid.Row="2">
                <StatusBarItem>
                    <TextBlock Name="StatusText" Text="就绪"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>

        <Grid Name="OperationOverlay" Background="#90000000" Visibility="Collapsed">
            <Border Background="White" CornerRadius="10" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="300">
                <StackPanel>
                    <TextBlock Name="OperationText" Text="处理中..." FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <ProgressBar Height="12" IsIndeterminate="True"/>
                    <Button Name="CancelOperationButton" Content="取消" Width="90" Height="32" HorizontalAlignment="Center" Margin="0,12,0,0" Click="CancelOperationButton_OnClick"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Name="StartupOverlay" Background="#F7F9FB">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Name="LoadingGifImage" Width="92" Height="92" Source="pack://siteoforigin:,,,/Assets/loading.gif" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <RotateTransform x:Name="LoadingRotate" Angle="0"/>
                    </Image.RenderTransform>
                </Image>
                <TextBlock Text="系统初始化中..." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

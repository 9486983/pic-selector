<Window x:Class="PhotoSelector.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:PhotoSelector.App.Converters"
        mc:Ignorable="d"
        x:Name="RootWindow"
        Title="Photo Selector"
        Background="#F5F7FB"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">
    <Window.Resources>
        <conv:RatingStarConverter x:Key="RatingStarConverter" />
        <conv:HexToBrushConverter x:Key="HexToBrushConverter" />
        <conv:StringHasValueToVisibilityConverter x:Key="StringHasValueToVisibilityConverter" />
        <conv:ThreeTwoHeightConverter x:Key="ThreeTwoHeightConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="ThumbListBoxItemStyleWithMenu" TargetType="ListBoxItem" BasedOn="{StaticResource ThumbListBoxItemStyle}">
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="PhotoListItem_OnPreviewMouseRightButtonDown"/>
            <EventSetter Event="MouseDoubleClick" Handler="PhotoListItem_OnMouseDoubleClick"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource UiBg}">
        <Grid Name="MainContentRoot" Opacity="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="12,12,12,8">
                <Button Name="BackToGalleryButton" Style="{StaticResource FlutterButton}" Margin="0,0,8,0" Content="返回图库" Click="BackToGalleryButton_OnClick" Visibility="Collapsed"/>
                <Button Name="ImportButton" Style="{StaticResource FlutterButton}" Margin="0,0,8,0" Content="导入文件夹" Click="ImportButton_OnClick"/>
                <Button Name="AnalyzeSelectedButton" Style="{StaticResource FlutterButton}" Margin="0,0,8,0" Content="分析选中" Click="AnalyzeSelectedButton_OnClick"/>
                <Button Name="AnalyzeAllButton" Style="{StaticResource FlutterButton}" Margin="0,0,8,0" Content="分析当前" Click="AnalyzeAllButton_OnClick"/>
                <Button Name="ApplyRuleButton" Style="{StaticResource FlutterButton}" Margin="0,0,8,0" Content="应用规则" Click="ApplyRuleButton_OnClick"/>
                <Button Name="ExportButton" Style="{StaticResource FlutterButton}" Margin="0,0,8,0" Content="导出筛选结果" Click="ExportButton_OnClick"/>
                <TextBox Name="RuleTextBox" VerticalContentAlignment="Center" Text="overall&gt;0.65 AND sharpness&gt;0.4 AND is_waste==false" />
            </DockPanel>

            <Grid Grid.Row="1" Margin="12,0,12,8">
                <Grid Name="GalleryPage" AllowDrop="True" DragOver="GalleryPage_OnDragOver" Drop="GalleryPage_OnDrop">
                    <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="12" Background="{StaticResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="图库（可拖拽文件夹到本页）" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ListBox Name="GalleryFolderList"
                                     Grid.Row="1"
                                     SelectionMode="Single"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="300" Height="270" Padding="4" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="10" Background="White">
                                            <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth}"
                                                  MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth}"
                                                  ClipToBounds="True">
                                                <Grid.Resources>
                                                    <Style TargetType="Button" x:Key="HoverCardActionBtn" BasedOn="{StaticResource FlutterButton}">
                                                        <Setter Property="Opacity" Value="0"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Resources>
                                                <StackPanel Margin="4,4,8,6" HorizontalAlignment="Stretch">
                                                    <Border Height="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth, Converter={StaticResource ThreeTwoHeightConverter}}"
                                                            Background="#FFFFFF"
                                                            CornerRadius="8"
                                                            ClipToBounds="True">
                                                        <Image Source="{Binding CoverPath}"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Margin="0,6,0,0" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding FolderPath}" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <Button HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8, 12" Style="{StaticResource HoverCardActionBtn}" Content="进入" Click="OpenLibraryFolder_OnClick" CommandParameter="{Binding}"/>
                                                <Button HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="24,50" Style="{StaticResource HoverCardActionBtn}" Content="..." Click="OpenLibraryMenu_OnClick" Tag="{Binding}">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="进入文件夹" Click="OpenLibraryFolderFromMenu_OnClick" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <Separator />
                                                            <MenuItem Header="从图库移除" Click="RemoveLibraryFolder_OnClick" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="删除磁盘文件夹" Click="DeleteLibraryFolderDisk_OnClick" CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Name="FolderPage" Visibility="Collapsed" SizeChanged="FolderPage_OnSizeChanged">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="1*" x:Name="DetailsColumn" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0" Background="{StaticResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="分类维度" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Grid.Row="1" BorderBrush="#D6DDE8" BorderThickness="1" CornerRadius="12" Padding="6" Background="White">
                                <TreeView Name="GroupList"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          SelectedItemChanged="GroupTree_OnSelectedItemChanged"
                                          ContextMenuOpening="GroupList_OnContextMenuOpening">
                                    <TreeView.ContextMenu>
                                        <ContextMenu/>
                                    </TreeView.ContextMenu>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <Border x:Name="TreeItemBorder" CornerRadius="8" Padding="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderBrush" Value="#2574A9"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsMouseOver}" Value="True">
                                                                <Setter Property="Background" Value="#F5F9FF"/>
                                                                <Setter Property="BorderBrush" Value="#C6D8F2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse
                                                             Margin="0,0,6,0"
                                                             Fill="{Binding ColorSwatch, Converter={StaticResource HexToBrushConverter}}"
                                                             Stroke="#B4C1D1"
                                                             StrokeThickness="0.5"
                                                             Visibility="{Binding ColorSwatch, Converter={StaticResource StringHasValueToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding Title}" Foreground="#1B2430"/>
                                                </StackPanel>
                                            </Border>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,10,0" Background="{StaticResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Name="FolderTitleText" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Name="FinishSelectionButton" Content="完成选片" Margin="0,0,12,0" Click="FinishSelectionButton_OnClick" Style="{StaticResource FlutterButton}"/>
                                    <TextBlock Text="排序" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Name="SortComboBox" SelectionChanged="SortComboBox_OnSelectionChanged" SelectedIndex="0" Margin="0,0,10,0" AllowDrop="True">
                                        <ComboBoxItem Tag="overall_desc">综合分 ↓</ComboBoxItem>
                                        <ComboBoxItem Tag="overall_asc">综合分 ↑</ComboBoxItem>
                                        <ComboBoxItem Tag="sharpness_desc">清晰度 ↓</ComboBoxItem>
                                        <ComboBoxItem Tag="exposure_desc">曝光 ↓</ComboBoxItem>
                                        <ComboBoxItem Tag="face_desc">人数 ↓</ComboBoxItem>
                                        <ComboBoxItem Tag="rating_desc">星级 ↓</ComboBoxItem>
                                        <ComboBoxItem Tag="captured_desc">拍摄时间 ↓</ComboBoxItem>
                                        <ComboBoxItem Tag="name_asc">文件名 ↑</ComboBoxItem>
                                    </ComboBox>
                                    <TextBlock Text="每排数量" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Slider Name="ColumnsSlider" Minimum="1" Maximum="10" Width="100" Value="5" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="ColumnsSlider_OnValueChanged"/>
                                    <TextBlock Name="ColumnsText" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <ListBox Name="PhotoList"
                                     Grid.Row="1"
                                     SelectionMode="Single"
                                     ItemContainerStyle="{StaticResource ThumbListBoxItemStyleWithMenu}"
                                     SelectionChanged="PhotoList_OnSelectionChanged"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding ElementName=RootWindow, Path=PhotoColumns}"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth}"
                                              MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth}"
                                              ClipToBounds="True">
                                            <Grid.Resources>
                                                <Style TargetType="Button" x:Key="HoverActionBtn" BasedOn="{StaticResource FlutterButton}">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="Button" x:Key="StarBtn">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="1"/>
                                                    <Setter Property="FontSize" Value="16"/>
                                                    <Setter Property="Foreground" Value="#D49B00"/>
                                                </Style>
                                            </Grid.Resources>
                                            <StackPanel Margin="4,4,8,6"
                                                        HorizontalAlignment="Stretch">
                                                <Border Height="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth, Converter={StaticResource ThreeTwoHeightConverter}}"
                                                        Background="Transparent"
                                                        BorderBrush="#D6DDE8"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        ClipToBounds="True">
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Text="{Binding FileName}"/>
                                                <TextBlock Foreground="#444" FontSize="12" Text="{Binding ScoreBadge}"/>
                                                <TextBlock Foreground="#666" FontSize="12" Text="{Binding MetaBadge}" TextTrimming="CharacterEllipsis"/>
                                                <Grid Margin="0,3,0,0"
                                                      Name="ThumbFooterGrid"
                                                      HorizontalAlignment="Stretch"
                                                      ClipToBounds="True"
                                                      MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth}"
                                                      Loaded="ThumbFooter_OnLoaded"
                                                      SizeChanged="ThumbFooter_OnSizeChanged">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel x:Name="StarPanel" Orientation="Horizontal" Margin="0,0,8,0">
                                                        <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=1}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="1"/>
                                                        <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=2}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="2"/>
                                                        <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=3}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="3"/>
                                                        <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=4}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="4"/>
                                                        <Button Style="{StaticResource StarBtn}" Content="{Binding Rating, Converter={StaticResource RatingStarConverter}, ConverterParameter=5}" Click="SetRating_OnClick" CommandParameter="{Binding}" Tag="5"/>
                                                    </StackPanel>
                                                    <StackPanel x:Name="SwatchPanel" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0" HorizontalAlignment="Right">
                                                        <Ellipse Width="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Height="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Margin="0,2,3,0"
                                                                 Fill="{Binding Color1, Converter={StaticResource HexToBrushConverter}}"
                                                                 Visibility="{Binding Color1, Converter={StaticResource StringHasValueToVisibilityConverter}}"/>
                                                        <Ellipse Width="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Height="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Margin="0,2,3,0"
                                                                 Fill="{Binding Color2, Converter={StaticResource HexToBrushConverter}}"
                                                                 Visibility="{Binding Color2, Converter={StaticResource StringHasValueToVisibilityConverter}}"/>
                                                        <Ellipse Width="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Height="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Margin="0,2,3,0"
                                                                 Fill="{Binding Color3, Converter={StaticResource HexToBrushConverter}}"
                                                                 Visibility="{Binding Color3, Converter={StaticResource StringHasValueToVisibilityConverter}}"/>
                                                        <Ellipse Width="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Height="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Margin="0,2,3,0"
                                                                 Fill="{Binding Color4, Converter={StaticResource HexToBrushConverter}}"
                                                                 Visibility="{Binding Color4, Converter={StaticResource StringHasValueToVisibilityConverter}}"/>
                                                        <Ellipse Width="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Height="{Binding ElementName=RootWindow, Path=FontSize}"
                                                                 Margin="0,2,0,0"
                                                                 Fill="{Binding Color5, Converter={StaticResource HexToBrushConverter}}"
                                                                 Visibility="{Binding Color5, Converter={StaticResource StringHasValueToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Foreground="#B00020" FontSize="12" Text="{Binding WasteBadge}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8, 12" Background="#E6F4EA" BorderBrush="#7FCF9B" BorderThickness="1" CornerRadius="8" Padding="6,2" Visibility="{Binding IsPicked, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="已选" Foreground="#1F6F3D"/>
                                            </Border>
                                            <Button HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8, 10" Content="全屏" Style="{StaticResource HoverActionBtn}" Click="FullscreenPreview_OnClick" CommandParameter="{Binding}" ToolTip="全屏预览"/>
                                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12, 10" Style="{StaticResource HoverActionBtn}" Content="..." Click="OpenRowMenu_OnClick" CommandParameter="{Binding}" ToolTip="更多操作">
                                                <Button.ContextMenu>
                                                    <ContextMenu/>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2" Name="DetailsPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="360" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,8" Background="{StaticResource CardBg}">
                            <Image Name="PreviewImage" Stretch="Uniform"/>
                        </Border>
                        <Border Grid.Row="1" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="10" Padding="12" Background="{StaticResource CardBg}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Name="DetailOverallText" Grid.Row="0" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailSharpnessText" Grid.Row="1" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailExposureText" Grid.Row="2" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailFaceText" Grid.Row="3" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailClassText" Grid.Row="4" Margin="0,0,0,6"/>
                                <TextBlock Name="DetailWasteText" Grid.Row="5" Margin="0,0,0,8"/>
                                <Border Name="ExifCard" Grid.Row="6" Background="#F8FAFD" BorderBrush="#D5DFEE" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="拍摄参数" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBlock Name="ExifIsoText" Margin="0,0,0,4"/>
                                        <TextBlock Name="ExifApertureText" Margin="0,0,0,4"/>
                                        <TextBlock Name="ExifShutterText" Margin="0,0,0,4"/>
                                        <TextBlock Name="ExifFocalText" Margin="0,0,0,4"/>
                                        <TextBlock Name="ExifCameraText"/>
                                        <TextBlock Name="ExifCapturedText"/>
                                    </StackPanel>
                                </Border>
                                <TextBox Name="DetailRawJsonText"
                                             Grid.Row="7"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             TextWrapping="Wrap"
                                             IsReadOnly="True"
                                             Background="#F8FAFD"
                                             BorderBrush="#D5DFEE"
                                             Foreground="#1E2936"
                                             Padding="8"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <StatusBar Grid.Row="2">
                <StatusBarItem>
                    <TextBlock Name="StatusText" Text="就绪"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>

        <Grid Name="OperationOverlay" Background="#90000000" Visibility="Collapsed">
            <Border Background="White" CornerRadius="10" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="300">
                <StackPanel>
                    <TextBlock Name="OperationText" Text="处理中..." FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <ProgressBar Height="12" IsIndeterminate="True"/>
                    <Button Name="CancelOperationButton" Content="取消" Width="90" Height="32" HorizontalAlignment="Center" Margin="0,12,0,0" Click="CancelOperationButton_OnClick"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Name="StartupOverlay" Background="#F7F9FB">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Name="LoadingGifImage" Width="92" Height="92" Source="pack://siteoforigin:,,,/Assets/loading.gif" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <RotateTransform x:Name="LoadingRotate" Angle="0"/>
                    </Image.RenderTransform>
                </Image>
                <TextBlock Text="系统初始化中..." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
















